{
  "manifest_version": 3,
  "name": "RoundScout for GeoGuessr",
  "version": "1.11.2",
  "description": "Post-round GeoGuessr visual coach, round tracker, and personalized learning dashboard.",
  "permissions": [
    "storage",
    "unlimitedStorage"
  ],
  "host_permissions": [
    "https://www.geoguessr.com/*",
    "https://geoguessr.com/*",
    "https://game-server.geoguessr.com/*",
    "https://api.bigdatacloud.net/*",
    "https://www.plonkit.net/*",
    "https://upload.wikimedia.org/*"
  ],
  "background": {
    "service_worker": "src/background.js"
  },
  "action": {
    "default_title": "Open GeoGuessr Study Stats"
  },
  "options_page": "src/stats.html",
  "content_scripts": [
    {
      "matches": [
        "https://www.geoguessr.com/*",
        "https://geoguessr.com/*"
      ],
      "js": [
        "src/page-probe.js"
      ],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": [
        "https://www.geoguessr.com/*",
        "https://geoguessr.com/*"
      ],
      "js": [
        "src/data.js",
        "src/clues.js",
        "src/capture-utils.js",
        "src/content.js"
      ],
      "css": [
        "src/styles.css"
      ],
      "run_at": "document_start",
      "world": "ISOLATED"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "src/page-probe.js",
        "src/stats.html"
      ],
      "matches": [
        "https://www.geoguessr.com/*",
        "https://geoguessr.com/*"
      ]
    }
  ]
}
